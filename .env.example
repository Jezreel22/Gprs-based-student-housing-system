# Required — Postgres connection string for Drizzle.
# Local dev: `npm run db:up` brings up the persistent `naub-pg` container
# via docker-compose (named volume `naub-pg-data`). The same string below
# matches the compose setup (POSTGRES_PASSWORD=dev, default `postgres` user/db).
DATABASE_URL=postgres://postgres:dev@localhost:5432/postgres

# Required — used to sign and verify the JWTs that the API issues.
# Any random string works in dev; rotate before production.
# Generate one with:  openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-string

# Optional — Google OAuth client ID used by @react-oauth/google on the client.
# If unset, the Google sign-in button is hidden in the UI.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional — public base path the app is mounted at (defaults to "").
# Mirrors the Vite-era BASE_URL constant for any code that still uses it.
NEXT_PUBLIC_BASE_PATH=

# Required for online escrow payments — Paystack secret key (server-side only).
# Get yours from https://dashboard.paystack.co/#/settings/developer.
# Use the test key (`sk_test_...`) during development and the live key
# (`sk_live_...`) in production. Used to verify charges and sign the webhook.
PAYSTACK_SECRET_KEY=

# Required for online escrow payments — Paystack public key (exposed to the
# browser to open the inline checkout popup). `pk_test_...` / `pk_live_...`.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Public origin of the deployed app, used to build Paystack callback URLs and
# metadata. e.g. http://localhost:3000 in dev, https://app.example.com in prod.
NEXT_PUBLIC_APP_URL=http://localhost:3000


# Real delivery-backed trust verification. Both providers are server-only;
# request/confirm endpoints fail closed until their keys are configured.
# Resend: https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM="NAUB Home Finder <verify@example.com>"
# Termii Nigerian SMS: https://termii.com/
TERMII_API_KEY=
TERMII_SENDER_ID=NAUBHomes
