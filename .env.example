# Required — Postgres connection string for Drizzle.
# Local dev: `npm run db:up` brings up the persistent `naub-pg` container
# via docker-compose (named volume `naub-pg-data`). The same string below
# matches the compose setup (POSTGRES_PASSWORD=dev, default `postgres` user/db).
DATABASE_URL=postgres://postgres:dev@localhost:5432/postgres

# Required — used to sign and verify the JWTs that the API issues.
# Any random string works in dev; rotate before production.
# Generate one with:  openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-string

# Optional — Google OAuth client ID used by @react-oauth/google on the client.
# If unset, the Google sign-in button is hidden in the UI.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional — public base path the app is mounted at (defaults to "").
# Mirrors the Vite-era BASE_URL constant for any code that still uses it.
NEXT_PUBLIC_BASE_PATH=

# Required for online escrow payments — Paystack secret key (server-side only).
# Get yours from https://dashboard.paystack.co/#/settings/developer.
# Use sk_test_ locally and sk_live_ only in the production deployment env.
# Live escrow payouts additionally require a Paystack Registered Business account.
PAYSTACK_SECRET_KEY=

# Browser-safe inline checkout key. Use pk_test_ locally, pk_live_ in production.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Public HTTPS origin of the deployed app. In Paystack's live dashboard, set the
# webhook URL to `${NEXT_PUBLIC_APP_URL}/api/payments/webhook` and enable
# charge.success, transfer.success, transfer.failed, and transfer.reversed.
NEXT_PUBLIC_APP_URL=http://localhost:3000


# Real delivery-backed trust verification. Both providers are server-only;
# request/confirm endpoints fail closed until their keys are configured.
# Resend: https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM="NAUB Home Finder <verify@example.com>"
# Termii Nigerian SMS: https://termii.com/
TERMII_API_KEY=
TERMII_SENDER_ID=NAUBHomes

# Escrow disbursement mode.
#   managed (default) — student approval queues the payout; the platform owner
#     pays the landlord by manual bank transfer and confirms it in the admin
#     Escrow tab ("Mark disbursed"). Real held-funds escrow that works on a
#     Paystack Starter account (which cannot use the third-party Transfer API).
#   transfer           — the app initiates a Paystack transfer to the landlord
#     automatically on student approval. Requires the Paystack account to be a
#     Registered Business. Switch to this after the upgrade.
ESCROW_DISBURSEMENT_MODE=managed

# ─── Maps (Mapbox GL) ────────────────────────────────────────────────────────
# Required for the /map page, the listing detail map, and the location picker.
# Get a free token (50k map loads/mo) at https://account.mapbox.com/access-tokens
# — use the "Default public token". It's safe to expose (restrict it by URL in
# the Mapbox dashboard, not by secrecy). If unset, the map shows an error and
# the location search falls back to the Nominatim-backed /api/geocode route.
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Google Maps (deprecated) ───────────────────────────────────────────────
# Previously used for the Maps JS API + Places Autocomplete. The app now uses
# Mapbox GL (above). These remain only as a server-side geocoding fallback for
# /api/geocode; the "Get directions" web links need no key.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional: a separate server-only API key for the /api/geocode proxy.
# Falls back to NEXT_PUBLIC_GOOGLE_MAPS_API_KEY when not set.
GOOGLE_MAPS_SERVER_API_KEY=
