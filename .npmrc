strict-peer-dependencies=false
fetch-retries=5
fetch-timeout=300000
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
# esbuild/sharp ship prebuilt binaries; their postinstall scripts are ignored
# (non-critical), so skip the strict pre-run dep check that pnpm 11 enforces.
verify-deps-before-run=false
